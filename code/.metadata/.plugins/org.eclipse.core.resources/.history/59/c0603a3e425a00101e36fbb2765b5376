void Motor_Run(uint32_t dir, uint32_t num, uint32_t speed)
{
    motor_flag = !motor_flag;
    if (dir == 1)
    {
        rt_pin_write(PIN_DIR, PIN_HIGH);
    }
    else if (dir == 0)
    {
        rt_pin_write(PIN_DIR, PIN_LOW);
    }

    for (uint32_t i = 0; i <= (num * 1600); i++)
    {
        if (motor_enabled)
        {
            rt_thread_mdelay(speed / 1000);
            rt_pin_write(PIN_PUL, !rt_pin_read(PIN_PUL)); // 脉冲引脚取反
        }
        else
        {
            break;
        }
    }
}

void panduan(void)
{

    if (humi < 30 && humi > 0) //开始浇水
    {
        waterStatus = 1;
        rt_pin_write(PIN_Pump_Water, PIN_HIGH);
        rt_pin_write(PIN_Valve_Left, PIN_HIGH);
    }

    if (humi > 30 || (humi < 5 && humi > 3)) //大于30停止浇水
    {
        waterStatus = 0;
        rt_pin_write(PIN_Pump_Water, PIN_LOW);
        rt_pin_write(PIN_Valve_Left, PIN_LOW);
    }

    if (n_data < 30 && n_data > 9) //土壤氮含量在9-30之间开始补肥料
    {
        NitriStatus = 1;
        rt_pin_write(PIN_Pump_Fertilizer, PIN_HIGH);
        rt_pin_write(PIN_Valve_Right, PIN_HIGH);
    }

    if (n_data > 30 && (n_data < 9 && n_data > 5)) //停止补肥料
    {
        NitriStatus = 0;
        rt_pin_write(PIN_Pump_Fertilizer, PIN_LOW);
