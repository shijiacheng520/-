        Motor_working_flag = 1;
        Motor_dir = 1;
        shadeStatus = 1;
    }

    if (als11 < 500 && shadeStatus_F == 1) //关闭遮阳棚
    {
        Motor_working_flag = 1;
        Motor_dir = 0;
        shadeStatus = 0;
    }

