    if (sht3x_temp < th_value) //停止通风
    {
        fanStatus = 0;
        rt_pin_write(PIN_Fan, PIN_LOW);
    }

    if (als11 >= 500) //停止补光
    {
        ledStatus = 0;
        rt_pin_write(PIN_Light_Left, PIN_HIGH);
        rt_pin_write(PIN_Light_Right, PIN_HIGH);
